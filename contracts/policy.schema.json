{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolicyGate Policy Config v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "policy_version",
    "default",
    "rules"
  ],
  "properties": {
    "policy_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "policy_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "default": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "rationale_codes"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "ALLOW",
            "BLOCK",
            "REQUIRE_REVIEW",
            "DEGRADE"
          ]
        },
        "rationale_codes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "priority",
          "when",
          "then"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "priority": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000000
          },
          "when": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "action"
            ],
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "infer:run",
                  "data:read",
                  "data:write",
                  "tool:invoke",
                  "policy:admin"
                ]
              },
              "env": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 64
                  }
                }
              },
              "resource": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 64
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                  },
                  "sensitivity": {
                    "type": "string",
                    "enum": [
                      "public",
                      "internal",
                      "restricted"
                    ]
                  }
                }
              },
              "subject": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 32
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                  }
                }
              },
              "signals": {
                "type": "object",
                "description": "Rule match on signals uses exact key/value equality.",
                "maxProperties": 50,
                "propertyNames": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]{0,40}$"
                },
                "additionalProperties": {
                  "oneOf": [
                    {
                      "type": "string",
                      "maxLength": 256
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "integer"
                    },
                    {
                      "type": "boolean"
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              }
            }
          },
          "then": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "decision",
              "rationale_codes"
            ],
            "properties": {
              "decision": {
                "type": "string",
                "enum": [
                  "ALLOW",
                  "BLOCK",
                  "REQUIRE_REVIEW",
                  "DEGRADE"
                ]
              },
              "rationale_codes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64
                }
              },
              "obligations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "type",
                    "params"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "OUTPUT_CAP"
                      ]
                    },
                    "params": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "max_tokens": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 100000
                        },
                        "max_items": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 1000000
                        },
                        "max_bytes": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 100000000
                        }
                      },
                      "minProperties": 1
                    }
                  }
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "decision": {
                      "const": "DEGRADE"
                    }
                  }
                },
                "then": {
                  "required": [
                    "obligations"
                  ]
                }
              }
            ]
          }
        }
      }
    }
  }
}