{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolicyGate EvaluateResponse v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "decision",
    "rationale_codes",
    "policy"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Request correlation id. Echoes request_id if provided, otherwise generated by PolicyGate."
    },
    "decision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "BLOCK",
        "REQUIRE_REVIEW",
        "DEGRADE"
      ]
    },
    "rationale_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    },
    "obligations": {
      "type": "array",
      "description": "Only present when decision=DEGRADE (or in future for other decisions, if explicitly supported).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "params"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "OUTPUT_CAP"
            ]
          },
          "params": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {
              "max_tokens": {
                "type": "integer",
                "minimum": 1,
                "maximum": 100000
              },
              "max_items": {
                "type": "integer",
                "minimum": 1,
                "maximum": 1000000
              },
              "max_bytes": {
                "type": "integer",
                "minimum": 1,
                "maximum": 100000000
              }
            }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "policy_version"
      ],
      "properties": {
        "policy_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "policy_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "matched_rule_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Rule that produced the decision (omitted if default applied or on fail-closed error)."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "DEGRADE"
          }
        }
      },
      "then": {
        "required": [
          "obligations"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "ALLOW"
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "obligations"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "BLOCK"
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "obligations"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "REQUIRE_REVIEW"
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "obligations"
          ]
        }
      }
    }
  ]
}